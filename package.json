{
  "name": "verbatims",
  "version": "0.104.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "dev": "nuxt dev",
    "db:sync-local": "node ./scripts/sync-local-db-from-wrangler.mjs",
    "facebook:token": "node ./scripts/generate-facebook-page-token.mjs",
    "facebook:token:write": "node ./scripts/generate-facebook-page-token.mjs from-user-token --write-env",
    "instagram:token": "node ./scripts/generate-instagram-token.mjs",
    "instagram:token:write": "node ./scripts/generate-instagram-token.mjs from-code --write-env",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "bump:version": "node ./scripts/bump-version.mjs patch",
    "bump:fix": "node ./scripts/bump-version.mjs fix",
    "bump:minor": "node ./scripts/bump-version.mjs minor",
    "bump:major": "node ./scripts/bump-version.mjs major",
    "version": "node ./scripts/tag-version.mjs",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@dayflow/blossom-color-picker-vue": "^1.2.1",
    "@libsql/client": "^0.17.4",
    "@noble/hashes": "^2.2.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/test-utils": "4.0.3",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/sitemap": "7.6.0",
    "@pinia/nuxt": "0.11.3",
    "@una-ui/nuxt": "^0.66.0",
    "@verbatims/social-autopost-core": "git+https://github.com/rootasjey/social-autopost-core.git#v0.1.0",
    "@vueuse/nuxt": "14.3.0",
    "fflate": "^0.8.3",
    "html-to-image": "^1.11.13",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "0.5.29",
    "pinia": "^3.0.4",
    "resend": "^6.16.0",
    "vue": "3.5.28",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/openmoji": "^1.2.27",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/solar": "^1.2.5",
    "@iconify-json/tabler": "^1.2.35",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jimp": "^1.6.1",
    "puppeteer": "^24.43.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.9",
    "vue-tsc": "3.2.5",
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "@vueuse/core": "14.3.0",
    "@vueuse/shared": "14.3.0"
  },
  "trustedDependencies": [
    "@verbatims/social-autopost-core"
  ]
}
